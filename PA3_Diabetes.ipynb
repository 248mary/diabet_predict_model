  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. Предобработка данных\n",
    "\n",
    "### Что делаем\n",
    "1. **Заменяем нули на NaN** в признаках, где 0 физически невозможен\n",
    "2. **Импутируем пропуски** медианой (устойчиво к выбросам)\n",
    "3. **Масштабируем признаки** через `StandardScaler` — необходимо для Logistic Regression\n",
    "4. **Стратифицированный split** — сохраняем баланс классов в train и test\n",
    "\n",
    "Всё упаковываем в `sklearn.Pipeline` — это предотвращает утечку данных (data leakage),\n",
    "потому что scaler обучается только на train, а не на всём датасете."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Заменяем физически невозможные нули на NaN\n",
    "df_clean = df.copy()\n",
    "zero_cols = ['Glucose', 'BloodPressure', 'SkinThickness', 'Insulin', 'BMI']\n",
    "for col in zero_cols:\n",
    "    df_clean[col] = df_clean[col].replace(0, np.nan)\n",
    "\n",
    "print('Пропуски после замены нулей на NaN:')\n",
    "missing = df_clean.isnull().sum()\n",
    "missing = missing[missing > 0]\n",
    "for col, n in missing.items():\n",
    "    print(f'  {col:30s}: {n} ({n/len(df_clean)*100:.1f}%)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Признаки и целевая переменная\n",
    "FEATURES = ['Pregnancies', 'Glucose', 'BloodPressure', 'SkinThickness',\n",
    "            'Insulin', 'BMI', 'DiabetesPedigreeFunction', 'Age']\n",
    "\n",
    "X = df_clean[FEATURES].values\n",
    "y = df_clean['Outcome'].values\n",
    "\n",
    "# Стратифицированный train/test split 80/20\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y,\n",
    "    test_size=0.2,\n",
    "    random_state=SEED,\n",
    "    stratify=y        # сохраняем пропорцию классов\n",
    ")\n",
    "\n",
    "print(f'Train: {X_train.shape}  |  Test: {X_test.shape}')\n",
    "print(f'Train — класс 0: {(y_train==0).sum()}, класс 1: {(y_train==1).sum()}')\n",
    "print(f'Test  — класс 0: {(y_test==0).sum()},  класс 1: {(y_test==1).sum()}')\n",
    "print()\n",
    "print('Баланс в train:', round((y_train==1).sum() / len(y_train), 3),\n",
    "      '  Баланс в test:', round((y_test==1).sum() / len(y_test), 3))\n",
    "print('Стратификация работает: пропорция одинакова')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["---\n## 5. Обучение ML-моделей"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Pipeline = Imputer + Scaler + Модель\n",
    "# Scaler обучается ТОЛЬКО на train — нет утечки данных\n",
    "\n",
    "pipelines = {\n",
    "    'Logistic Regression': Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('scaler',  StandardScaler()),\n",
    "        ('model',   LogisticRegression(\n",
    "            C=0.5,\n",
    "            max_iter=1000,\n",
    "            random_state=SEED,\n",
    "            class_weight='balanced'   # учитываем дисбаланс классов\n",
    "        ))\n",
    "    ]),\n",
    "    'Random Forest': Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('model',   RandomForestClassifier(\n",
    "            n_estimators=300,\n",
    "            max_depth=8,              # ограничиваем глубину — защита от переобучения\n",
    "            min_samples_leaf=4,       # минимум 4 примера в листе\n",
    "            min_samples_split=8,\n",
    "            class_weight='balanced',  # учитываем дисбаланс\n",
    "            random_state=SEED,\n",
    "            n_jobs=-1\n",
    "        ))\n",
    "    ]),\n",
    "    'Gradient Boosting': Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('model',   GradientBoostingClassifier(\n",
    "            n_estimators=200,\n",
    "            max_depth=4,\n",
    "            learning_rate=0.05,\n",
    "            subsample=0.8,            # стохастический GB — снижает переобучение\n",
    "            min_samples_leaf=4,\n",
    "            random_state=SEED\n",
    "        ))\n",
    "    ]),\n",
    "}\n",
    "\n",
    "results = {}\n",
    "for name, pipe in pipelines.items():\n",
    "    pipe.fit(X_train, y_train)\n",
    "\n",
    "    train_pred = pipe.predict(X_train)\n",
    "    test_pred  = pipe.predict(X_test)\n",
    "    test_proba = pipe.predict_proba(X_test)[:, 1]\n",
    "\n",
    "    train_acc = accuracy_score(y_train, train_pred)\n",
    "    test_acc  = accuracy_score(y_test,  test_pred)\n",
    "    test_f1   = f1_score(y_test, test_pred, average='weighted')\n",
    "    test_roc  = roc_auc_score(y_test, test_proba)\n",
    "    test_prec = precision_score(y_test, test_pred)\n",
    "    test_rec  = recall_score(y_test, test_pred)\n",
    "    gap       = train_acc - test_acc\n",
    "\n",
    "    results[name] = {\n",
    "        'train_acc': train_acc,\n",
    "        'test_acc':  test_acc,\n",
    "        'f1':        test_f1,\n",
    "        'roc_auc':   test_roc,\n",
    "        'precision': test_prec,\n",
    "        'recall':    test_rec,\n",
    "        'gap':       gap,\n",
    "        'preds':     test_pred,\n",
    "        'proba':     test_proba,\n",
    "    }\n",
    "    print(f'{name}:')\n",
    "    print(f'  Train Acc={train_acc:.4f}  Test Acc={test_acc:.4f}  '\n",
    "          f'Gap={gap:.4f}  F1={test_f1:.4f}  ROC-AUC={test_roc:.4f}')\n",
    "\n",
    "print('\\nВсе модели обучены')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5-fold Stratified Cross-Validation — честная оценка\n",
    "print('5-fold Stratified Cross-Validation (ROC-AUC):')\n",
    "print('-' * 55)\n",
    "\n",
    "skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "\n",
    "for name, pipe in pipelines.items():\n",
    "    cv_scores = cross_val_score(\n",
    "        pipe, X, y,\n",
    "        cv=skf,\n",
    "        scoring='roc_auc',\n",
    "        n_jobs=-1\n",
    "    )\n",
    "    print(f'{name}:')\n",
    "    print(f'  ROC-AUC per fold: {np.round(cv_scores, 3)}')\n",
    "    print(f'  Mean: {cv_scores.mean():.4f} +/- {cv_scores.std():.4f}')\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["---\n## 6. Оценка качества"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сводная таблица метрик\n",
    "df_summary = pd.DataFrame([\n",
    "    {\n",
    "        'Модель':      name,\n",
